pair = input('Pair: ').upper()
entry = float(input('Entry: '))
stop_loss = float(input('Stop loss: '))
lot_size = float(input('Lot size: '))
pip_value = 10


def calculate_pips(entry, stop_loss):
	pips = (entry - stop_loss) * 10000
	return pips

def calculate_risk_dollars(pips, lot_size):
	dollar_risk = pips * lot_size * pip_value
	return dollar_risk

def display_summary(pair, pips, dollars):
	print('---- Trade Risk Calculator ----')
	print('Pips:', pips)
	print('Pair:', pair)
	print('Dollars:', dollars)

pips = calculate_pips(entry, stop_loss)
dollars = calculate_risk_dollars(pips, lot_size)
display_summary(pair, pips, dollars)
