pair = input('Pair: ').upper()
def calculate_pips(entry, stop_loss):
	pips = float(entry - stop_loss)
	pip_value = float((entry - stop_loss) * 10000)
	return pip_value

def calculate_risk_dollars(pips, lot_size, pip_value):
	dollar_risk = (pips * lot_size * pip_value)
	return dollar_risk

def display_summary(pair, pips_value, dollar_risk):
	print('---- Trade Risk Calculator ----')
	print(f'Pair; {pair}')
	print(f'Risk in pips: {pips_value}')
	print(f'Risk in Dollars: {dollar_risk}')

calculate_pips()
calculate_risk_dollars()
display_summary()


